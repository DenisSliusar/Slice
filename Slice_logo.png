  spendingCategories: { ru: "Категории расходов", en: "Spending Categories" },
  smartDivision: { ru: "Умное разделение счетов", en: "Smart Account Division" },
  appleWallet: { ru: "Apple Wallet", en: "Apple Wallet" },
